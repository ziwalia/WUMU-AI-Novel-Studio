{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/static/tauri-schema-v2.json",
  "productName": "乌木智书-WUMU AI Novel",
  "version": "0.1.0",
  "identifier": "com.ai-novel-studio.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "乌木智书-WUMU AI Novel",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": [
        "style-src"
      ],
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' https: ws://127.0.0.1:* http://127.0.0.1:* ws://localhost:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
